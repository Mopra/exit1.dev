# Firebase Service Account — path to downloaded JSON key file.
# applicationDefault() in init.ts reads this automatically via the standard
# Google Cloud ADC (Application Default Credentials) chain.
GOOGLE_APPLICATION_CREDENTIALS=/opt/exit1/service-account.json

# Clerk API keys (used by defineSecret().value() which reads process.env on VPS)
CLERK_SECRET_KEY_PROD=sk_live_...
CLERK_SECRET_KEY_DEV=sk_test_...

# Resend (email alerts)
RESEND_API_KEY=re_...
RESEND_FROM=Exit1.dev <alerts@updates.exit1.dev>

# Twilio (SMS alerts)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
TWILIO_MESSAGING_SERVICE_SID=MG...

# Region this VPS is responsible for. Must match a value in the CheckRegion
# union (functions/src/check-region.ts). Defaults to vps-eu-1 if unset.
# Frankfurt: vps-eu-1
# Boston:    vps-us-1
VPS_REGION_ID=vps-eu-1

# VPS performance overrides (optional, defaults to Cloud Functions values)
# Raise these on VPS hardware to use full capacity. Cloud Functions ignores these.
# MAX_CONCURRENT_CHECKS_OVERRIDE=250
# BATCH_SIZE_OVERRIDE=500

# Manual check HTTP API — Cloud Functions proxy requests here so checks
# originate from the VPS static IP. The secret must match the Cloud Functions
# VPS_MANUAL_CHECK_SECRET secret.
VPS_MANUAL_CHECK_SECRET=your-shared-secret-here
VPS_HTTP_PORT=3100

# DNS servers for the c-ares resolver (comma-separated).
# Defaults to Cloudflare + Google if not set. Bypasses the VPS provider's
# potentially slow default resolver.
# DNS_SERVERS=1.1.1.1,8.8.8.8,1.0.0.1
